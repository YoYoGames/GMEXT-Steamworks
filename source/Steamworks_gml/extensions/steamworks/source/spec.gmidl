// Steam Remote Storage constants
const SteamRemoteStorageFilenameMax : int32 = 260;
const SteamRemoteStoragePublishedDocumentChangeDescriptionMax : int32 = 8000;
const SteamRemoteStoragePublishedDocumentDescriptionMax : int32 = 8000;
const SteamRemoteStoragePublishedDocumentTitleMax : int32 = 129;
const SteamRemoteStoragePublishedFileUrlMax : int32 = 256;
const SteamRemoteStorageTagListMax : int32 = 1025;
const SteamRemoteStoragePublishedFileIdInvalid : int32 = 0;
const SteamRemoteStoragePublishedFileUpdateHandleInvalid : int64 = -1;
const SteamRemoteStorageUgcFileStreamHandleInvalid : int64 = -1;
const SteamRemoteStorageUgcHandleInvalid : int64 = -1;
const SteamRemoteStorageEnumeratePublishedFilesMaxResults : int32 = 50;
const SteamRemoteStorageMaxCloudFileChunkSize : int32 = 104857600;
const SteamRemoteStorageInterfaceVersion : string = "STEAMREMOTESTORAGE_INTERFACE_VERSION014";

[global, bind = typed_gml]
enum SteamRemoteStoragePlatform
{
    None = 0,
    Windows = 1,
    OSX = 2,
    PS3 = 4,
    Linux = 8,
    Reserved2 = 16,
