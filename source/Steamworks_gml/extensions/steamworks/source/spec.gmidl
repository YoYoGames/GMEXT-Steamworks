// EFriendFlags (bitmask used by GetFriendCount / GetFriendByIndex) 
[global, bind = typed_gml]
enum SteamFriendsFriendFlag
{
    None = 0,

    Blocked            = 1,        // 1 << 0
    FriendshipRequested = 2,      // 1 << 1
    Immediate          = 4,        // 1 << 2
    ClanMember        = 8,        // 1 << 3
    OnGameServer     = 16,       // 1 << 4
    RequestingFriendship = 128,   // 1 << 7
    RequestingInfo    = 256,      // 1 << 8
    Ignored            = 512,      // 1 << 9
    IgnoredFriend     = 1024,     // 1 << 10
    ChatMember        = 4096,     // 1 << 12
    All                = 65535,    // 0xFFFF
}

