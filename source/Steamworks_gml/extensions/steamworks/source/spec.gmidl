group{ // SteamInventory

// Steam Inventory constants (https://partner.steamgames.com/doc/api/isteaminventory#constants)
// These are plain constants, not an enum: SteamInventoryResultInvalid is the k_SteamInventoryResultInvalid value.
const SteamInventoryResultInvalid : int32 = -1;
const SteamInventoryItemInstanceIdInvalid : int64 = -1;
const SteamInventoryInterfaceVersion : string = "STEAMINVENTORY_INTERFACE_V002";

// From ESteamItemFlags (bit flags) - used by SteamInventoryResultItems.flags
[global, bind = typed_gml]
enum SteamInventoryItemFlags
{
    NoTrade = 1,      // 1 << 0  - account-locked, cannot be traded or given away
    Removed = 256,    // 1 << 8  - item destroyed/traded/expired/invalidated (result-set only)
    Consumed = 512,   // 1 << 9  - item quantity decreased by 1 via ConsumeItem (result-set only)
}

// Helper struct for ExchangeItems / GenerateItems / StartPurchase
[global]
class `[[SteamInventoryItemDefQuantity]]` prototype Object
