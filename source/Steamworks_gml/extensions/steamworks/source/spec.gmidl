    [field] property result : int32 { get; set; }       // EResult numeric
    [field] property app_id : uint32 { get; set; }
    [field] property applicable : bool { get; set; }
    [field] property csecs_last_5h : int32 { get; set; }
    [field, type_hint=`SteamUserDurationControlProgress`] property progress : gmval { get; set; }
    [field, type_hint=`SteamUserDurationControlNotification`] property notification : gmval { get; set; }
}

// From EDurationControlProgress - used by SteamUserDurationControl.progress
[global, bind = typed_gml]
enum SteamUserDurationControlProgress
{
    Full = 0,             // Full progress
    Half = 1,             // deprecated - XP or persistent rewards should be halved
    None = 2,             // deprecated - XP or persistent rewards should be stopped
    ExitSoon_3h = 3,      // allowed 3h time since 5h gap/break has elapsed, game should exit
    ExitSoon_5h = 4,      // allowed 5h time in calendar day has elapsed, game should exit
    ExitSoon_Night = 5,   // game running after day period, game should exit
}

// From EDurationControlNotification - used by SteamUserDurationControl.notification
[global, bind = typed_gml]
enum SteamUserDurationControlNotification
{
    None = 0,             // just informing you about progress, no notification to show
    OneHour = 1,          // "you've been playing for N hours" (k_EDurationControlNotification_1Hour)
    ThreeHours = 2,       // deprecated - "you've been playing for 3 hours; take a break"
    HalfProgress = 3,     // deprecated - "your XP / progress is half normal"
    NoProgress = 4,       // deprecated - "your XP / progress is zero"
    ExitSoon_3h = 5,      // allowed 3h time since 5h gap/break has elapsed, game should exit
    ExitSoon_5h = 6,      // allowed 5h time in calendar day has elapsed, game should exit
    ExitSoon_Night = 7,   // game running after day period, game should exit
}

