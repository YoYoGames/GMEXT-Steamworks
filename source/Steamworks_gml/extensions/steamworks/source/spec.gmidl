    // EResult of the ticket request (k_EResultOK on success).
    [field, type_hint = `SteamApiResult`]
    property result : gmval { get; set; }
}

// EBeginAuthSessionResult
[global, bind = typed_gml]
enum SteamUserBeginAuthSessionResult
{
    Ok = 0,
    InvalidTicket = 1,
    DuplicateRequest = 2,
    InvalidVersion = 3,
    GameMismatch = 4,
    ExpiredTicket = 5,
}

// From EAuthSessionResponse - delivered by ValidateAuthTicketResponse_t (m_eAuthSessionResponse)
[global, bind = typed_gml]
enum SteamAuthSessionResponse
{
    OK = 0,                                  // ticket is valid and has not been reused
    UserNotConnectedToSteam = 1,             // the user is not connected to steam
    NoLicenseOrExpired = 2,                  // the license has expired
    VACBanned = 3,                           // the user is VAC banned for this game
    LoggedInElseWhere = 4,                   // the user logged in elsewhere and the session was disconnected
    VACCheckTimedOut = 5,                    // VAC could not perform anti-cheat checks on this user
    AuthTicketCanceled = 6,                  // the ticket was canceled by the issuer
    AuthTicketInvalidAlreadyUsed = 7,        // this ticket has already been used, it is not valid
    AuthTicketInvalid = 8,                   // this ticket is not from a user instance currently connected to steam
    PublisherIssuedBan = 9,                  // the user is banned for this game (web api ban, not VAC)
    AuthTicketNetworkIdentityFailure = 10,   // the network identity in the ticket does not match the authenticating server
}

// EDurationControlOnlineState 
[global, bind = typed_gml]
enum SteamUserDurationControlOnlineState
{
    Invalid = 0,
    Offline = 1,
    Online = 2,
    OnlineHighPri = 3,
}

// GetAvailableVoice (out params)
// Steam returns EVoiceResult and fills bytes available for compressed + optional uncompressed
[global, bind = typed_gml, type_hint=`SteamUserAvailableVoice`]
