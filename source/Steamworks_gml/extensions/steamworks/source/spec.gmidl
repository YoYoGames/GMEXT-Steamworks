[gml_api]
module Steamworks;


[global]
class `[[SteamId]]` prototype Object
{
    [field, type_hint = uint64]
    property id64 : gmval { get; set; }

    [field]
    property account_id : uint32 { get; set; }        // GetAccountID()

    [field]
    property account_instance : uint32 { get; set; }  // GetUnAccountInstance()

    [field, type_hint = `SteamApiUniverse`]
    property universe : gmval { get; set; }           // GetEUniverse()

    [field, type_hint = `SteamApiAccountType`]
    property account_type : gmval { get; set; }       // GetEAccountType()

    // Common identity predicates
    [field]
    property is_valid : bool { get; set; }            // IsValid()

    [field]
    property is_lobby : bool { get; set; }            // IsLobby()

    //Internal Steam debug function....
    // [field]
    // property is_valid_external : bool { get; set; }   // BValidExternalSteamID()

    // Account-type predicates
    [field]
    property is_individual : bool { get; set; }       // BIndividualAccount()

    [field]
    property is_game_server : bool { get; set; }      // BGameServerAccount()

    [field]
    property is_anon_game_server : bool { get; set; } // BAnonGameServerAccount()

    [field]
    property is_anon_user : bool { get; set; }        // BAnonUserAccount()

    [field]
    property is_content_server : bool { get; set; }   // BContentServerAccount()

    [field]
    property is_clan : bool { get; set; }             // BClanAccount()

    [field]
    property is_chat : bool { get; set; }             // BChatAccount()
}


[global, bind = typed_gml]
enum SteamApiAccountType
{
    Invalid = 0,
    Individual = 1,
    Multiseat = 2,
    GameServer = 3,
    AnonGameServer = 4,
    Pending = 5,
    ContentServer = 6,
    Clan = 7,
    Chat = 8,
    ConsoleUser = 9,
    AnonUser = 10,
}

