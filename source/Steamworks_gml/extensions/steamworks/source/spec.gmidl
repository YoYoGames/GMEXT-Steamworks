// From EItemState (bit flags) - returned by steam_ugc_get_item_state
[global, bind = typed_gml]
enum SteamUgcItemState
{
    None = 0,             // item not tracked on client
    Subscribed = 1,       // current user is subscribed to this item (not just cached)
    LegacyItem = 2,       // item was created with ISteamRemoteStorage
    Installed = 4,        // item is installed and usable (but maybe out of date)
    NeedsUpdate = 8,      // item needs an update (not installed yet, or creator updated content)
    Downloading = 16,     // item update is currently downloading
    DownloadPending = 32, // DownloadItem() was called, content unavailable until DownloadItemResult_t fires
    DisabledLocally = 64, // item is disabled locally, so it shouldn't be considered subscribed
}

// From EItemUpdateStatus - used by SteamUgcItemUpdateProgress.status
[global, bind = typed_gml]
enum SteamUgcItemUpdateStatus
{
    Invalid = 0,               // the item update handle was invalid, job might be finished
    PreparingConfig = 1,       // processing configuration data
    PreparingContent = 2,      // reading and processing content files
    UploadingContent = 3,      // uploading content changes to Steam
    UploadingPreviewFile = 4,  // uploading new preview file image
    CommittingChanges = 5,     // committing all changes
}

[global]
class `[[SteamUgcItemUpdateProgress]]` prototype Object
{
    [field, type_hint=`SteamUgcItemUpdateStatus`]
    property status : gmval { get; set; }

    [field, type_hint = uint64]
    property bytes_processed : gmval { get; set; }

    [field, type_hint = uint64]
    property bytes_total : gmval { get; set; }
}

// EItemStatistic
[global, bind = typed_gml]
enum SteamUgcStatisticType
{
    NumSubscriptions = 0,
    NumFavorites = 1,
    NumFollowers = 2,
    NumUniqueSubscriptions = 3,
    NumUniqueFavorites = 4,
    NumUniqueFollowers = 5,
    NumUniqueWebsiteViews = 6,
    ReportScore = 7,
    NumSecondsPlayed = 8,
    NumPlaytimeSessions = 9,
    NumComments = 10,
    NumSecondsPlayedDuringTimePeriod = 11,
    NumPlaytimeSessionsDuringTimePeriod = 12,
}

