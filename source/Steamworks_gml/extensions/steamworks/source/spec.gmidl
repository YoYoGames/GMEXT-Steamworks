const SteamFriendsFriendsGroupLimit : int32 = 100;
const SteamFriendsChatMetadataMax : int32 = 8192;
const SteamFriendsPersonaNameMaxUtf16 : int32 = 32;
const SteamFriendsGroupIdInvalid : int32 = -1;
const SteamFriendsInterfaceVersion : string = "SteamFriends015";

[global]
class `[[SteamFriendsGetFollowerCountResult]]` prototype Object
{
    [field, type_hint = `SteamApiResult`] property result : gmval { get; set; }
