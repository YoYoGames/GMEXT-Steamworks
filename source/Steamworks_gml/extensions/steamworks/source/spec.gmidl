[gml_api]
module Steamworks;


[global]
class `[[SteamId]]` prototype Object
{
    [field, type_hint = uint64]
    property id64 : gmval { get; set; }

    [field]
    property account_id : uint32 { get; set; }        // GetAccountID()

    [field]
    property account_instance : uint32 { get; set; }  // GetUnAccountInstance()

    [field, type_hint = `SteamApiUniverse`]
    property universe : gmval { get; set; }           // GetEUniverse()

    [field, type_hint = `SteamApiAccountType`]
    property account_type : gmval { get; set; }       // GetEAccountType()

    // Common identity predicates
    [field]
    property is_valid : bool { get; set; }            // IsValid()

    [field]
    property is_lobby : bool { get; set; }            // IsLobby()

    //Internal Steam debug function....
    // [field]
    // property is_valid_external : bool { get; set; }   // BValidExternalSteamID()

    // Account-type predicates
    [field]
    property is_individual : bool { get; set; }       // BIndividualAccount()

    [field]
    property is_game_server : bool { get; set; }      // BGameServerAccount()

    [field]
    property is_anon_game_server : bool { get; set; } // BAnonGameServerAccount()

    [field]
    property is_anon_user : bool { get; set; }        // BAnonUserAccount()

    [field]
    property is_content_server : bool { get; set; }   // BContentServerAccount()

    [field]
    property is_clan : bool { get; set; }             // BClanAccount()

    [field]
    property is_chat : bool { get; set; }             // BChatAccount()
}


[global, bind = typed_gml]
enum SteamApiAccountType
{
    Invalid = 0,
    Individual = 1,
    Multiseat = 2,
    GameServer = 3,
    AnonGameServer = 4,
    Pending = 5,
    ContentServer = 6,
    Clan = 7,
    Chat = 8,
    ConsoleUser = 9,
    AnonUser = 10,
}

group
{
// Steam API / shared constants
const SteamApiBreakpadInvalidHandle : int32 = 0;
const SteamApiGameExtraInfoMax : int32 = 64;
const SteamApiSaltSize : int32 = 8;
const SteamApiGidNil : int64 = -1;
const SteamApiAuthTicketInvalid : int32 = 0;
const SteamApiJobIdNil : int64 = -1;
const SteamApiTxnIdNil : int64 = -1;
const SteamApiTxnIdUnknown : int32 = 0;
const SteamApiApiCallInvalid : int32 = 0x0;
const SteamApiAppIdInvalid : int32 = 0x0;
const SteamApiBundleIdInvalid : int32 = 0;
const SteamApiCellIdInvalid : int32 = 0xFFFFFFFF;
const SteamApiDepotIdInvalid : int32 = 0x0;
const SteamApiAssetClassIdInvalid : int32 = 0x0;
const SteamApiManifestIdInvalid : int32 = 0;
const SteamApiSteamAccountIdMask : int32 = 0xFFFFFFFF;
const SteamApiSteamAccountInstanceMask : int32 = 0x000FFFFF;
const SteamApiSteamUserConsoleInstance : int32 = 2;
const SteamApiSteamUserDesktopInstance : int32 = 1;
const SteamApiSteamUserWebInstance : int32 = 4;
const SteamApiPackageIdFreeSub : int32 = 0x0;
const SteamApiPackageIdInvalid : int32 = 0xFFFFFFFF;
const SteamApiPartnerIdInvalid : int32 = 0;
const SteamApiPhysicalItemIdInvalid : int32 = 0x0;
const SteamApiQueryPortError : int32 = 0xFFFE;
const SteamApiQueryPortNotInitialized : int32 = 0xFFFF;


[global, bind = typed_gml]
function steam_api_last_error(): string;

// auxiliar function
[global, bind = typed_gml]
function steam_api_is_initialized(): bool;

// SteamAPI_Init
[global, bind = typed_gml]
function steam_api_init(own_app_id: uint32): bool;

// SteamAPI_ReleaseCurrentThreadMemory
[global, bind = typed_gml]
function steam_api_release_current_thread_memory(): unit;

// SteamAPI_RestartAppIfNecessary
[global, bind = typed_gml]
function steam_api_restart_app_if_necessary(own_app_id: uint32): bool;

// SteamAPI_RunCallbacks
[global, bind = typed_gml]
function steam_api_run_callbacks(): unit;

// SteamAPI_Shutdown
[global, bind = typed_gml]
function steam_api_shutdown(): unit;


// From EDenyReason 
[global, bind = typed_gml]
enum SteamApiDenyReason
{
    Invalid = 0,
    InvalidVersion = 1,
    Generic = 2,
    NotLoggedOn = 3,
    NoLicense = 4,
    Cheater = 5,
    LoggedInElsewhere = 6,
    UnknownText = 7,
    IncompatibleAnticheat = 8,
    MemoryCorruption = 9,
    IncompatibleSoftware = 10,
    SteamConnectionLost = 11,
    SteamConnectionError = 12,
    SteamResponseTimedOut = 13,
    SteamValidationStalled = 14,
    SteamOwnerLeftGuestUser = 15,
}

// From EGameIDType 
[global, bind = typed_gml]
enum SteamApiGameIdType
{
    App = 0,
    GameMod = 1,
    Shortcut = 2,
    P2p = 3,
}

// From ELaunchOptionType 
[global, bind = typed_gml]
enum SteamApiLaunchOptionType
{
    None = 0,
    Default = 1,
    SafeMode = 2,
    Multiplayer = 3,
    Config = 4,
    Openvr = 5,
    Server = 6,
    Editor = 7,
    Manual = 8,
    Benchmark = 9,
    Option1 = 10,
    Option2 = 11,
    Option3 = 12,
    OculusVr = 13,
    OpenvrOverlay = 14,
    Osvr = 15,
    Dialog = 1000,
}

// From EMarketingMessageFlags (bit flags) 
[global, bind = typed_gml]
enum SteamApiMarketingMessageFlag
{
    None = 0,
    HighPriority = 1,        // 1 << 0
    PlatformWindows = 2,     // 1 << 1
    PlatformMac = 4,         // 1 << 2
    PlatformLinux = 8,       // 1 << 3
    PlatformRestrictions = 14, // aggregate of platform flags
}

// From ENotificationPosition 
[global, bind = typed_gml]
enum SteamApiNotificationPosition
{
    TopLeft = 0,
    TopRight = 1,
    BottomLeft = 2,
    BottomRight = 3,
}

// From EUniverse 
[global, bind = typed_gml]
enum SteamApiUniverse
{
    Invalid = 0,
    Public = 1,
    Beta = 2,
    Internal = 3,
    Dev = 4,
    Max = 5,
}

// From EUserHasLicenseForAppResult 
[global, bind = typed_gml]
enum SteamApiUserHasLicenseForAppResult
{
    HasLicense = 0,
    DoesNotHaveLicense = 1,
    NoAuth = 2,
}

// From EVoiceResult 
[global, bind = typed_gml]
enum SteamApiVoiceResult
{
    Ok = 0,
    NotInitialized = 1,
    NotRecording = 2,
    NoData = 3,
    BufferTooSmall = 4,
    DataCorrupted = 5,
    Restricted = 6,
    UnsupportedCodec = 7,
    ReceiverOutOfDate = 8,
    ReceiverDidNotAnswer = 9,
}

// From EResult (Steam result codes) 
