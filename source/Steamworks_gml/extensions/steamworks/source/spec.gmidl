group{ // SteamInput

// Steam Input constants
const SteamInputInterfaceVersion : string = "SteamInput001";
const SteamInputHandleAllControllers : int64 = -1;
const SteamInputMaxAnalogActions : int32 = 16;
const SteamInputMaxAnalogActionData : real = 1.0;
const SteamInputMaxCount : int32 = 16;
const SteamInputMaxDigitalActions : int32 = 128;
const SteamInputMaxOrigins : int32 = 8;
const SteamInputMinAnalogActionData : real = -1.0;

// From EInputSourceMode (docs: EControllerSourceMode) - used by SteamInputAnalogActionData.mode
[global, bind = typed_gml]
enum SteamInputControllerSourceMode
{
    None = 0,
    Dpad = 1,
    Buttons = 2,
    FourButtons = 3,
    AbsoluteMouse = 4,
    RelativeMouse = 5,
    JoystickMove = 6,
    JoystickMouse = 7,
    JoystickCamera = 8,
    ScrollWheel = 9,
    Trigger = 10,
    TouchMenu = 11,
    MouseJoystick = 12,
    MouseRegion = 13,
    RadialMenu = 14,
    SingleButton = 15,
    Switches = 16,
}

// From ESteamInputLEDFlag (docs: ESteamControllerLEDFlag) - bitmask used by steam_input_set_led_color
[global, bind = typed_gml]
enum SteamInputControllerLEDFlag
{
    SetColor = 0,
    RestoreUserDefault = 1,
}

// From EInputGlyphSize - used by steam_input_get_glyph_png_for_action_origin
[global, bind = typed_gml]
enum SteamInputGlyphSize
{
    Small = 0,
    Medium = 1,
    Large = 2,
    Count = 3,
}

// From EInputGlyphStyle - used by steam_input_get_glyph_png_for_action_origin and steam_input_get_glyph_svg_for_action_origin
[global, bind = typed_gml]
enum SteamInputGlyphStyle
{
    Knockout = 0,
    Light = 1,
    Dark = 2,
    NeutralColorABXY = 16,
    SolidABXY = 32,
}

// From ESteamInputType - returned by steam_input_get_input_type_for_handle
[global, bind = typed_gml]
enum SteamInputType
{
    Unknown = 0,
    SteamController = 1,
    XBox360Controller = 2,
    XBoxOneController = 3,
    GenericGamepad = 4,         // DirectInput controllers
    PS4Controller = 5,
    AppleMFiController = 6,     // Unused
    AndroidController = 7,      // Unused
    SwitchJoyConPair = 8,       // Unused
    SwitchJoyConSingle = 9,     // Unused
    SwitchProController = 10,
    MobileTouch = 11,           // Steam Link App On-screen Virtual Controller
    PS3Controller = 12,         // Currently uses PS4 Origins
    PS5Controller = 13,
    SteamDeckController = 14,
    Count = 15,
    MaximumPossibleValue = 255,
}

// From EXboxOrigin - used by steam_input_get_action_origin_from_xbox_origin
[global, bind = typed_gml]
enum SteamInputXboxOrigin
{
    A = 0,
    B = 1,
    X = 2,
    Y = 3,
    LeftBumper = 4,
    RightBumper = 5,
    Menu = 6,
    View = 7,
    LeftTrigger_Pull = 8,
