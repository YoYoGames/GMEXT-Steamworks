// From EBetaBranchFlags (bit flags) - used by SteamAppsBetaInfo.flags
[global, bind = typed_gml]
enum SteamAppsBetaBranchFlags
{
    None = 0,
    Default = 1,      // the default branch ("public")
    Available = 2,    // this branch can be selected (available)
    Private = 4,      // this is a private branch (password protected)
    Selected = 8,     // this is the currently selected branch (active)
    Installed = 16,   // this is the currently installed branch (mounted)
}

