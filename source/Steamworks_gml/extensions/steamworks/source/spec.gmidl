// EPersonaState (commonly used by SteamFriends; numeric mapping is stable across SDKs)
[global, bind = typed_gml]
enum SteamFriendsPersonaState
{
    Offline = 0,
    Online = 1,
    Busy = 2,
    Away = 3,
    Snooze = 4,
    LookingToTrade = 5,
    LookingToPlay = 6,
}

// EFriendRelationship (relationship between the local user and the specified SteamID)
[global, bind = typed_gml]
enum SteamFriendsRelationship
{
    None = 0,
    Blocked = 1,
    RequestRecipient = 2,
    Friend = 3,
    RequestInitiator = 4,
    Ignored = 5,
    IgnoredFriend = 6,
    SuggestedFriend = 7,
}

