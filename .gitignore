# VS and VSC folders
**/.vs/
**/.vsc/

# Common extensions
**/*.exp
**/*.ilk
**/*.lib
**/*.pdb
**/*.exp
**/*.exe

# Steamworks SDKs
source/Steamworks_sdk/

# Steamworks third-party runtime libs (deployed at build time by
# post_build_step.bat/.sh from the SDK, never committed into the extension)
source/Steamworks_gml/extensions/steamworks/steam_api64.dll
source/Steamworks_gml/extensions/steamworks/libsteam_api.dylib
source/Steamworks_gml/extensions/steamworks/libsteam_api.so

# Steamworks DEMO options
source/Steamworks_gml/options/

# Steamworks build solutions (temp & output)
**/Debug/
**/Release/

# MacOS
.DS_Store

# XCode and VS userdata
*.user
xcuserdata/

# Release packages
output/
source/Steamworks_gml/extensions/steamworks/scriptUtils.bat.bak

source/Steamworks_gml/extensions/steamworks/scriptUtils.sh.bak
